{
  "name": "aevum",
  "version": "1.1.5",
  "private": true,
  "description": "Aevum desktop productivity assistant",
  "author": "ArturKamnev",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc -p electron/tsconfig.json && concurrently -k \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "dist": "npm run build && npm run build:electron && electron-builder --publish never",
    "release": "npm run build && npm run build:electron && electron-builder --publish always",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArturKamnev/todo-list.git"
  },
  "build": {
    "appId": "com.kamartur.aevum",
    "productName": "Aevum",
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName} Setup ${version}.${ext}",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "ArturKamnev",
        "repo": "todo-list"
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Aevum"
    }
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "electron-updater": "^6.8.3",
    "gsap": "^3.15.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.556.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  }
}
